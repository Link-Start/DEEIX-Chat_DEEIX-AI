{
  "name": "@deeix/chat-monorepo",
  "version": "0.3.3",
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "api:check": "pnpm --filter @deeix/api-contract check",
    "api:generate": "pnpm --filter @deeix/api-contract generate",
    "build": "turbo run build",
    "check": "turbo run check",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@deeix/api",
    "dev:web": "turbo run dev --filter=@deeix/web",
    "test": "turbo run test",
    "verify": "turbo run check test build"
  },
  "devDependencies": {
    "turbo": "2.10.5"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.7",
      "brace-expansion@1": "1.1.15",
      "brace-expansion@5": "5.0.6",
      "dompurify": "3.4.11",
      "flatted": "3.4.2",
      "js-yaml": "4.2.0",
      "mermaid": "11.15.0",
      "minimatch@3": "3.1.5",
      "picomatch": "4.0.4",
      "postcss": "8.5.10",
      "uuid": "11.1.1"
    }
  }
}
